{
  "rewrites": [
    { "source": "/admin", "destination": "/public/admin/index.html" },
    { "source": "/cobros", "destination": "/public/cobros.html" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/alumnos?action=cron&tipo=inicio", "schedule": "0 11 1 * *" },
    { "path": "/api/alumnos?action=cron&tipo=bloqueo", "schedule": "0 11 5 * *" }
  ]
}
